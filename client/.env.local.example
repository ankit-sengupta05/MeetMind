# ==========================================
# MeetMind Client Environment Variables
# ==========================================
# Rename this file to `.env.local` and fill in your app details.
# DO NOT commit the actual `.env.local` file to version control.

# The Azure AD Tenant ID where your app registration lives
VITE_AZURE_AD_TENANT_ID=your-azure-ad-tenant-id

# The Azure AD Client ID (Application ID) for your MeetMind Single Page App
VITE_AZURE_AD_CLIENT_ID=your-azure-ad-client-id

# The URL MSAL should redirect to after login (e.g. http://localhost:3000)
VITE_REDIRECT_URI=http://localhost:3000

# The base URL for your MeetMind backend API (e.g. http://localhost:3001)
VITE_API_BASE_URL=http://localhost:3001
