# ==============================================================================
# MeetMind – Environment Variables Reference
# Copy this file to .env (server), .env.local (client) and fill in real values.
# NEVER commit .env files to git. They are in .gitignore.
# ==============================================================================

# ------------------------------------------------------------------------------
# RUNTIME
# ------------------------------------------------------------------------------
NODE_ENV=development                         # development | staging | production
PORT=3001                                    # Express server port
CORS_ORIGINS=http://localhost:3000           # Comma-separated allowed origins

# ------------------------------------------------------------------------------
# MICROSOFT IDENTITY PLATFORM (Azure AD App Registration)
# Portal: https://portal.azure.com → Azure Active Directory → App registrations
# ------------------------------------------------------------------------------
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # Directory (tenant) ID
AZURE_AD_CLIENT_ID=******   # Application (client) ID
AZURE_AD_CLIENT_SECRET=******   # Client secret value (not ID)

# ------------------------------------------------------------------------------
# AZURE COSMOS DB (NoSQL API)
# Portal: Cosmos DB account → Keys → URI + PRIMARY KEY
# Recommended SKU: Serverless (dev/test), Provisioned 400 RU/s (prod)
# ------------------------------------------------------------------------------
COSMOS_ENDPOINT=https://meetmind-cosmos.documents.azure.com:443/
COSMOS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx==
COSMOS_DATABASE_NAME=meetmind

# ------------------------------------------------------------------------------
# AZURE OPENAI SERVICE
# Portal: Azure OpenAI → Resource → Keys and Endpoint
# Required deployments: gpt-4o (chat) + text-embedding-3-small (embeddings)
# ------------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://meetmind-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=******
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o                       # Your deployment name for GPT-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # Your deployment name for embeddings
AZURE_OPENAI_API_VERSION=2024-04-01-preview               # Check Azure OpenAI docs for latest

# ------------------------------------------------------------------------------
# AZURE AI SEARCH (formerly Cognitive Search)
# Portal: Search service → Settings → Keys
# Recommended SKU: Standard S1 (enables semantic ranker)
# ------------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://meetmind-search.search.windows.net
AZURE_SEARCH_ADMIN_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SEARCH_INDEX_NAME=meetmind-meetings

# ------------------------------------------------------------------------------
# MICROSOFT GRAPH API
# Uses a separate app registration OR the same as AZURE_AD above
# Required permissions: User.Read, Tasks.ReadWrite, Calendars.Read,
#   OnlineMeetings.Read, Group.Read.All
# Grant admin consent in Portal → API permissions
# ------------------------------------------------------------------------------
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_ID=******
GRAPH_CLIENT_SECRET=******

# ------------------------------------------------------------------------------
# MICROSOFT PLANNER
# Get groupId: Graph Explorer → /me/joinedGroups
# Get planId: /groups/{groupId}/planner/plans
# ------------------------------------------------------------------------------
PLANNER_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx     # MS 365 Group ID
PLANNER_PLAN_ID=xxxxxxxxxxxxxxxxxxxxxxxx                   # Planner plan ID

# ------------------------------------------------------------------------------
# BOT FRAMEWORK (Teams Bot)
# Portal: dev.botframework.com OR Azure Bot resource
# The bot must be registered and the messaging endpoint set to:
#   https://<your-domain>/api/v1/bot/messages
# ------------------------------------------------------------------------------
BOT_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx           # Bot application ID
BOT_APP_PASSWORD=******         # Bot client secret

# ------------------------------------------------------------------------------
# AZURE SERVICE BUS
# Portal: Service Bus namespace → Shared access policies → RootManageSharedAccessKey
# Create a queue named: meetmind-agent-jobs
# ------------------------------------------------------------------------------
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://meetmind-sb.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=xxxx
SERVICEBUS_QUEUE_NAME=meetmind-agent-jobs

# ------------------------------------------------------------------------------
# AZURE BLOB STORAGE (for recording/transcript artifacts)
# Portal: Storage account → Access keys → Connection string
# Create a container named: meetmind-artifacts
# ------------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=meetmindstorage;AccountKey=xxxx==;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=meetmind-artifacts

# ------------------------------------------------------------------------------
# INTERNAL JWT (service-to-service auth, NOT the MSAL token)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters
# ------------------------------------------------------------------------------
JWT_SECRET=******

# ------------------------------------------------------------------------------
# AZURE FUNCTIONS (agents/functions reference only)
# URL of the deployed indexMeeting Azure Function (HTTP trigger)
# ------------------------------------------------------------------------------
FUNCTION_INDEX_MEETING_URL=https://meetmind-functions.azurewebsites.net/api/indexMeeting?code=xxxx

# ==============================================================================
# CLIENT-SIDE VITE VARIABLES (prefix: VITE_)
# These go in client/.env.local and are embedded into the browser bundle.
# Never put secrets here — they are visible to users.
# ==============================================================================
VITE_AZURE_AD_CLIENT_ID=******  # Same as AZURE_AD_CLIENT_ID
VITE_AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # Same as AZURE_AD_TENANT_ID
VITE_REDIRECT_URI=http://localhost:3000                         # Must match AAD app redirect URIs
VITE_API_BASE_URL=/api/v1                                       # Proxied to server in dev; full URL in prod
