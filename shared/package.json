{
  "name": "@meetmind/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript types, interfaces, and utilities for MeetMind",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^5.0.7",
    "typescript": "^5.5.2"
  }
}
