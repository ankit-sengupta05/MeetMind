{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "node",
    "FUNCTIONS_NODE_BLOCK_ON_ENTRY_POINT_ERROR": "true",

    "COSMOS_ENDPOINT": "https://meetmind-cosmos.documents.azure.com:443/",
    "COSMOS_KEY": "your-cosmos-primary-key",
    "COSMOS_DATABASE_NAME": "meetmind",

    "AZURE_OPENAI_ENDPOINT": "https://meetmind-openai.openai.azure.com/",
    "AZURE_OPENAI_API_KEY": "your-openai-api-key",
    "AZURE_OPENAI_CHAT_DEPLOYMENT": "gpt-4o",
    "AZURE_OPENAI_EMBEDDING_DEPLOYMENT": "text-embedding-3-small",
    "AZURE_OPENAI_API_VERSION": "2024-04-01-preview",

    "AZURE_SEARCH_ENDPOINT": "https://meetmind-search.search.windows.net",
    "AZURE_SEARCH_ADMIN_KEY": "your-search-admin-key",
    "AZURE_SEARCH_INDEX_NAME": "meetmind-meetings",

    "SERVICEBUS_CONNECTION_STRING": "Endpoint=sb://meetmind-sb.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key",
    "SERVICEBUS_QUEUE_NAME": "meetmind-agent-jobs"
  },
  "Host": {
    "LocalHttpPort": 7071,
    "CORS": "*",
    "CORSCredentials": false
  }
}
